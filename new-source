AutofarmTab:Space()

AutofarmTab:Toggle({
    Title = "Auto Sell",
    Desc = "Automatically sells when backpack is full",
    Callback = function(state)
        getgenv().AutoSell = state
        if state then
            spawn(function()
                local CurrentNinjitsu = LocalPlayer.leaderstats.Ninjitsu
                local GroundBelts = ReplicatedStorage.Belts.Ground
                local CurrentBelt = LocalPlayer.equippedBelt.Value

                CurrentNinjitsu:GetPropertyChangedSignal("Value"):Connect(function()
                    if getgenv().AutoSell and CurrentNinjitsu.Value >= GroundBelts[CurrentBelt.Name].capacity.Value then
                        pcall(function()
                            local sellPart = Workspace.sellAreaCircles.sellAreaCircle.circleInner
                            firetouchinterest(sellPart, LocalPlayer.Character.Head, 1)
                            wait(0.5)
                            firetouchinterest(sellPart, LocalPlayer.Character.Head, 0)
                        end)
                    end
                end)
            end)
        end
    end
})

AutofarmTab:Toggle({
    Title = "Auto Sell (Always)",
    Desc = "Continuously sells without checking capacity",
    Callback = function(state)
        getgenv().AutoSellAlways = state
        if state then
            spawn(function()
                while getgenv().AutoSellAlways do
                    wait(0.1)
                    pcall(function()
                        local sellFolder = Workspace:FindFirstChild("sellAreaCircles")
                        if sellFolder then
                            local target = sellFolder:FindFirstChild("sellAreaCircle16") or 
                                         sellFolder:FindFirstChild("sellAreaCircle15") or 
                                         sellFolder:FindFirstChild("sellAreaCircle") or
                                         sellFolder:GetChildren()[1]
                            if target and target:FindFirstChild("circleInner") then
                                if target.circleInner:FindFirstChild("TouchInterest") then
                                    firetouchinterest(LocalPlayer.Character.Head, target.circleInner, 0)
                                    wait(0.05)
                                    firetouchinterest(LocalPlayer.Character.Head, target.circleInner, 1)
                                else
                                    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                                        LocalPlayer.Character.HumanoidRootPart.CFrame = target.circleInner.CFrame
                                    end
                                end
                            end
                        end
                    end)
                end
            end)
        end
    end
})

