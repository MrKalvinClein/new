MiscTab:Input({
    Title = "Keybind",
    Placeholder = "Enter keybind",
    Callback = function(text)
        if text and #text > 0 then
            if isMobile then
                WindUI:Notify({
                    Title = "Mobile Device",
                    Content = "You cant change keybind on mobile, use the open gui button instead",
                    Duration = 2,
                })
                return
            end
            
            if #text > 1 then
                WindUI:Notify({
                    Title = "Invalid Keybind",
                    Content = "You cant put a keybind that has more than 1 letter",
                    Duration = 2,
                })
                return
            end
            
            local keyName = string.upper(text)
            
            if keyName == "K" then
                WindUI:Notify({
                    Title = "Invalid Keybind",
                    Content = "This is already the default keybind",
                    Duration = 2,
                })
                return
            end
            
            if tonumber(keyName) then
                WindUI:Notify({
                    Title = "Invalid Keybind",
                    Content = "You cant put a number as a keybind",
                    Duration = 2,
                })
                return
            end
            
            local restrictedKeys = {"A", "S", "D", "W", "SPACE", "UP", "DOWN", "LEFT", "RIGHT", "ESCAPE", "LEFTSHIFT", "SHIFT", "LSHIFT"}
            if table.find(restrictedKeys, keyName) then
                WindUI:Notify({
                    Title = "Invalid Key",
                    Content = "You cant use movement keys",
                    Duration = 2,
                })
                return
            end
            
            local keyCode = Enum.KeyCode[keyName]
            if keyCode then
                Window:SetToggleKey(keyCode)
                
                Window:EditOpenButton({
                    Title = "Keybind: " .. keyName,
                    Icon = "grip",
                    CornerRadius = UDim.new(0,16),
                    StrokeThickness = 2,
                    OnlyMobile = false,
                    Enabled = true,
                    Draggable = false,
                })
                
                WindUI:Notify({
                    Title = "Keybind Updated",
                    Content = "Menu toggle keybind changed to: " .. keyName,
                    Duration = 2,
                })
            else
                WindUI:Notify({
                    Title = "Invalid Keybind",
                    Content = "Keybind '" .. text .. "' is not valid",
                    Duration = 2,
                })
            end
        end
    end
})

